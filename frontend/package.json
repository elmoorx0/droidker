{
  "name": "droidker-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "SvelteKit dashboard for the DroidKer Android micro-container platform",
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 0.0.0.0 --port 3000",
