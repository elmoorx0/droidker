# Backend daemon configuration via env vars.
# Copy to .env and adjust. Every DROIDKER_* var maps to a field in Settings.

DROIDKER_HOST=0.0.0.0
DROIDKER_PORT=8080
DROIDKER__DATA_DIR=/var/lib/droidker
DROIDKER__ANDROID_ROOTFS=/opt/droidker/android-rootfs
DROIDKER__MAX_CONTAINERS=8
DROIDKER__CONTAINER_MEMORY_MB=128
DROIDKER__CONTAINER_CPU_PERCENT=50
DROIDKER__BRIDGE_NAME=droidker0
DROIDKER__BRIDGE_SUBNET=10.244.0.0/16

# CLI overrides
# DROIDKER_HOST=http://127.0.0.1:8080
# DROIDKER_OUTPUT=pretty

# Logging
RUST_LOG=info,droidker_backend=debug
